{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core + dialog + the app's own sidecar/open commands for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "allow-sidecar-send",
    "allow-open-video",
    "allow-open-folder"
  ]
}
